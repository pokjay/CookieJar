# ── Auth ─────────────────────────────────────────────────────────────────────
# Required. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-me-with-a-random-secret

# Required. The shared family password used to log in.
AUTH_PASSWORD=replace-me-with-a-strong-password

# Required. Set to the URL the browser uses to reach the app.
# Local dev example (adjust port to match your docker-compose ports mapping):
NEXTAUTH_URL=http://localhost:3001
# On a hosted platform, use the public URL instead:
# NEXTAUTH_URL=https://your-app.onrender.com

# ── Data ─────────────────────────────────────────────────────────────────────
# USE_MOCK_DATA=true  → local seeded postgres (docker-compose.db.yml overlay spins it up)
# USE_MOCK_DATA=false → real prod DB from DATABASE_URL below, no local DB is started
USE_MOCK_DATA=true

# When USE_MOCK_DATA=true: uncomment to load the db overlay (starts postgres + db-seed).
# When USE_MOCK_DATA=false: leave commented — backend uses DATABASE_URL directly, no local DB.
# COMPOSE_FILE=docker-compose.yml:docker-compose.db.yml

# Your prod/real DB connection string (used when USE_MOCK_DATA=false).
# The options=-csearch_path%3Dmoneyman param lets table names be used without schema prefix.
DATABASE_URL=postgresql://user:password@host:5432/dbname?options=-csearch_path%3Dmoneyman

# Separate test database for integration tests (used by pytest -m integration)
# Point this at a dedicated test DB, never at production.
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/family_finance_test?options=-csearch_path%3Dmoneyman
